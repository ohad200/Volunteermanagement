<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ניהול התנדבות</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800&display=swap');

  :root {
    --bg: #f0f4f8;
    --surface: #ffffff;
    --primary: #2d6a4f;
    --primary-light: #52b788;
    --accent: #e76f51;
    --text: #1b1b2f;
    --muted: #6b7280;
    --border: #d1d5db;
    --pending: #f97316;
    --approved: #16a34a;
    --rejected: #dc2626;
    --proposed: #2563eb;
    --radius: 12px;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Heebo', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    direction: rtl;
  }

  /* BANNER */
  #banner-area {
    display: none;
    background: linear-gradient(90deg, var(--primary), var(--primary-light));
    color: white;
    text-align: center;
    padding: 10px 20px;
    font-size: 15px;
    font-weight: 600;
    position: relative;
  }

  /* TOP BAR */
  .topbar {
    background: var(--surface);
    border-bottom: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-logo {
    font-size: 22px;
    font-weight: 800;
    color: var(--primary);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .topbar-logo span { font-size: 28px; }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .user-greeting {
    font-size: 14px;
    color: var(--muted);
    font-weight: 500;
  }

  .btn {
    padding: 8px 18px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-family: 'Heebo', sans-serif;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary { background: var(--primary); color: white; }
  .btn-primary:hover { background: #1e4d38; }
  .btn-outline { background: transparent; border: 2px solid var(--primary); color: var(--primary); }
  .btn-outline:hover { background: var(--primary); color: white; }
  .btn-danger { background: var(--rejected); color: white; }
  .btn-danger:hover { background: #b91c1c; }
  .btn-sm { padding: 5px 12px; font-size: 13px; }

  /* SCREENS */
  .screen { display: none; }
  .screen.active { display: block; }

  /* LOGIN SCREEN */
  #login-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    padding: 40px 20px;
  }

  .login-card {
    background: var(--surface);
    border-radius: 20px;
    padding: 48px 40px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
  }

  .login-icon {
    width: 80px; height: 80px;
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    margin: 0 auto 24px;
  }

  .login-card h2 {
    text-align: center;
    font-size: 26px;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 8px;
  }

  .login-card p {
    text-align: center;
    color: var(--muted);
    margin-bottom: 32px;
    font-size: 14px;
  }

  .form-group { margin-bottom: 18px; }
  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .form-group input, .form-group textarea, .form-group select {
    width: 100%;
    padding: 11px 14px;
    border: 2px solid var(--border);
    border-radius: 8px;
    font-family: 'Heebo', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: #fafafa;
    transition: border-color 0.2s;
    direction: rtl;
  }

  .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
    outline: none;
    border-color: var(--primary);
    background: white;
  }

  .error-msg {
    color: var(--rejected);
    font-size: 13px;
    margin-top: 8px;
    display: none;
  }

  /* MAIN LAYOUT */
  #main-screen { padding: 20px 24px; }

  .main-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* CALENDAR */
  .calendar-card {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .calendar-header {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
  }

  .calendar-header h2 { font-size: 20px; font-weight: 700; }

  .cal-nav {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    width: 36px; height: 36px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 18px;
    transition: background 0.2s;
  }
  .cal-nav:hover { background: rgba(255,255,255,0.35); }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    background: #f8faf9;
    border-bottom: 1px solid var(--border);
  }

  .calendar-weekdays div {
    text-align: center;
    padding: 10px 0;
    font-size: 13px;
    font-weight: 700;
    color: var(--primary);
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .cal-day {
    background: var(--surface);
    min-height: 110px;
    padding: 8px;
    cursor: pointer;
    transition: background 0.15s;
    position: relative;
  }

  .cal-day:hover { background: #f0faf4; }
  .cal-day.other-month { background: #fafafa; }
  .cal-day.other-month .day-num { color: #ccc; }
  .cal-day.today { background: #ecfdf5; }
  .cal-day.today .day-num {
    background: var(--primary);
    color: white;
    border-radius: 50%;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
  }

  .day-num {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
  }

  .vol-chip {
    font-size: 11px;
    font-weight: 600;
    border-radius: 6px;
    padding: 2px 6px;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
  }

  .chip-pending { background: #fed7aa; color: #9a3412; border-right: 3px solid var(--pending); }
  .chip-approved { background: #bbf7d0; color: #14532d; border-right: 3px solid var(--approved); }
  .chip-rejected { background: #fecaca; color: #7f1d1d; border-right: 3px solid var(--rejected); }
  .chip-proposed { background: #bfdbfe; color: #1e3a5f; border-right: 3px solid var(--proposed); }

  /* LEGEND */
  .legend-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
  }

  .legend-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 14px;
    border-bottom: 2px solid var(--border);
    padding-bottom: 8px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 500;
  }

  .legend-dot {
    width: 14px; height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* VOLUNTEER FORM */
  .vol-form-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
  }

  .vol-form-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 18px;
  }

  .success-msg {
    background: #ecfdf5;
    border: 2px solid var(--approved);
    border-radius: 10px;
    padding: 16px;
    color: #14532d;
    font-weight: 600;
    text-align: center;
    margin-top: 16px;
    display: none;
  }

  /* ADMIN PANEL */
  #admin-screen { padding: 20px 24px; }

  .admin-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .admin-card {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .admin-card-header {
    background: linear-gradient(135deg, #1e3a5f, #2563eb);
    color: white;
    padding: 16px 20px;
    font-size: 16px;
    font-weight: 700;
  }

  .admin-card-body { padding: 20px; }

  .vol-request-item {
    border: 2px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    margin-bottom: 12px;
    position: relative;
  }

  .vol-request-item.pending { border-right: 4px solid var(--pending); }
  .vol-request-item.approved { border-right: 4px solid var(--approved); }
  .vol-request-item.rejected { border-right: 4px solid var(--rejected); }
  .vol-request-item.proposed { border-right: 4px solid var(--proposed); }

  .req-name { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
  .req-detail { font-size: 13px; color: var(--muted); margin-bottom: 2px; }
  .req-actions { margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap; }

  .btn-approve { background: var(--approved); color: white; }
  .btn-approve:hover { background: #15803d; }
  .btn-reject { background: var(--rejected); color: white; }
  .btn-reject:hover { background: #b91c1c; }
  .btn-propose { background: var(--proposed); color: white; }
  .btn-propose:hover { background: #1d4ed8; }

  /* USER MANAGEMENT */
  .user-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 8px;
  }

  .user-item-info .name { font-weight: 700; font-size: 14px; }
  .user-item-info .sub { font-size: 12px; color: var(--muted); }
  .user-item-actions { display: flex; gap: 6px; }

  /* MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }

  .modal-header {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: white;
    padding: 20px 24px;
    border-radius: 16px 16px 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-header h3 { font-size: 18px; font-weight: 700; }
  .modal-close {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    width: 32px; height: 32px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 18px;
    display: flex; align-items: center; justify-content: center;
  }

  .modal-body { padding: 24px; }

  /* TABS */
  .tabs {
    display: flex;
    gap: 4px;
    background: #f3f4f6;
    border-radius: 10px;
    padding: 4px;
    margin-bottom: 20px;
  }

  .tab {
    flex: 1;
    padding: 8px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Heebo', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    background: transparent;
    transition: all 0.2s;
  }

  .tab.active { background: white; color: var(--primary); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

  /* STATUS BADGE */
  .status-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
  }

  .badge-pending { background: #fed7aa; color: #9a3412; }
  .badge-approved { background: #bbf7d0; color: #14532d; }
  .badge-rejected { background: #fecaca; color: #7f1d1d; }
  .badge-proposed { background: #bfdbfe; color: #1e3a5f; }

  /* BANNER ADMIN */
  .banner-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: #f3f4f6;
    border-radius: 8px;
    margin-bottom: 8px;
    font-size: 14px;
  }

  .section-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .full-span { grid-column: 1 / -1; }

  .nav-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    max-width: 1200px;
    margin-right: auto;
    margin-left: auto;
  }

  .nav-tab {
    padding: 10px 20px;
    border-radius: 10px;
    border: 2px solid var(--border);
    background: white;
    cursor: pointer;
    font-family: 'Heebo', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    transition: all 0.2s;
  }

  .nav-tab.active { background: var(--primary); color: white; border-color: var(--primary); }
  .nav-tab:hover:not(.active) { border-color: var(--primary); color: var(--primary); }

  /* Volunteer personal area */
  #personal-screen { padding: 20px 24px; }
  .personal-grid { max-width: 900px; margin: 0 auto; }

  .my-vol-card {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .my-vol-header {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .my-vol-header.pending { background: #fff7ed; border-right: 4px solid var(--pending); }
  .my-vol-header.approved { background: #f0fdf4; border-right: 4px solid var(--approved); }
  .my-vol-header.rejected { background: #fef2f2; border-right: 4px solid var(--rejected); }
  .my-vol-header.proposed { background: #eff6ff; border-right: 4px solid var(--proposed); }

  .confirm-proposed-row {
    padding: 14px 20px;
    background: #f8faff;
    border-top: 1px solid #dbeafe;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  textarea { resize: vertical; min-height: 80px; }

  .inline-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .password-wrap {
    position: relative;
  }
  .password-wrap input {
    padding-left: 44px !important;
  }
  .pw-toggle {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    color: var(--muted);
    padding: 0;
    line-height: 1;
    user-select: none;
  }
  .pw-toggle:hover { color: var(--primary); }
</style>
</head>
<body>

<!-- BANNER AREA -->
<div id="banner-area"></div>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-logo">
    <span>🤝</span>
    ניהול התנדבות
  </div>
  <div class="topbar-right">
    <span class="user-greeting" id="user-greeting" style="display:none"></span>
    <button class="btn btn-outline" id="personal-btn" style="display:none" onclick="showPersonal()">האזור האישי שלי</button>
    <button class="btn btn-outline" id="admin-btn" style="display:none" onclick="showAdmin()">ניהול מנהל</button>
    <button class="btn btn-primary" id="calendar-btn" style="display:none" onclick="showCalendar()">לוח שנה</button>
    <button class="btn btn-danger" id="logout-btn" style="display:none" onclick="logout()">התנתק</button>
  </div>
</div>

<!-- =================== LOGIN SCREEN =================== -->
<div id="login-screen" class="screen active">
  <div class="login-card">
    <div class="login-icon">🤝</div>
    <h2>ניהול התנדבות</h2>
    <p>אנא התחבר עם שם המשתמש והסיסמה שקיבלת</p>
    <div class="form-group">
      <label>שם משתמש</label>
      <input type="text" id="login-username" placeholder="הכנס שם משתמש" />
    </div>
    <div class="form-group">
      <label>סיסמה</label>
      <div class="password-wrap">
        <input type="password" id="login-password" placeholder="הכנס סיסמה" />
        <button type="button" class="pw-toggle" onclick="togglePw('login-password',this)" title="הצג/הסתר סיסמה">👁️</button>
      </div>
    </div>
    <div class="error-msg" id="login-error">שם משתמש או סיסמה שגויים</div>
    <button class="btn btn-primary" style="width:100%;padding:12px;font-size:16px;margin-top:8px;" onclick="doLogin()">כניסה</button>
  </div>
</div>

<!-- =================== MAIN (CALENDAR) SCREEN =================== -->
<div id="main-screen" class="screen">
  <div class="main-grid">
    <!-- Calendar -->
    <div>
      <div class="calendar-card">
        <div class="calendar-header">
          <button class="cal-nav" onclick="prevMonth()">&#8250;</button>
          <h2 id="cal-title"></h2>
          <button class="cal-nav" onclick="nextMonth()">&#8249;</button>
        </div>
        <div class="calendar-weekdays">
          <div>א׳</div><div>ב׳</div><div>ג׳</div><div>ד׳</div><div>ה׳</div><div>ו׳</div><div>ש׳</div>
        </div>
        <div class="calendar-grid" id="cal-grid"></div>
      </div>
    </div>

    <!-- Sidebar -->
    <div>
      <!-- Legend -->
      <div class="legend-card">
        <h3>🎨 מקרא צבעים</h3>
        <div class="legend-item">
          <div class="legend-dot" style="background:var(--pending)"></div>
          <span><strong>כתום</strong> – ממתין לאישור מנהל</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background:var(--approved)"></div>
          <span><strong>ירוק</strong> – התנדבות אושרה</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background:var(--rejected)"></div>
          <span><strong>אדום</strong> – התנדבות נדחתה</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background:var(--proposed)"></div>
          <span><strong>כחול</strong> – שעות חדשות הוצעו ע״י מנהל</span>
        </div>
      </div>

      <!-- Volunteer Form -->
      <div class="vol-form-card" id="vol-form-container">
        <h3>📝 הרשמה להתנדבות</h3>
        <p style="font-size:13px;color:var(--muted);margin-bottom:16px;" id="selected-date-label">בחר יום בלוח השנה להרשמה</p>
        <div id="vol-form-fields" style="display:none">
          <div class="inline-row">
            <div class="form-group">
              <label>שם פרטי</label>
              <input type="text" id="vf-fname" placeholder="שם פרטי" readonly style="background:#f3f4f6;color:#888" />
            </div>
            <div class="form-group">
              <label>שם משפחה</label>
              <input type="text" id="vf-lname" placeholder="שם משפחה" readonly style="background:#f3f4f6;color:#888" />
            </div>
          </div>
          <div class="form-group">
            <label>טלפון</label>
            <input type="text" id="vf-phone" placeholder="טלפון" readonly style="background:#f3f4f6;color:#888" />
          </div>
          <div class="form-group">
            <label>שעות התנדבות</label>
            <input type="text" id="vf-hours" value="10:00-13:00" placeholder="10:00-13:00" />
          </div>
          <div class="form-group">
            <label>הסבר לשינוי שעות (אם שינית)</label>
            <input type="text" id="vf-hours-note" placeholder="לדוגמה: יכול רק מ-14:00" />
          </div>
          <div class="form-group">
            <label>הערות כלליות</label>
            <textarea id="vf-notes" placeholder="הערות נוספות (אופציונלי)"></textarea>
          </div>
          <button class="btn btn-primary" style="width:100%" onclick="submitVolunteer()">שלח בקשת התנדבות</button>
          <div class="success-msg" id="vol-success">✅ ההתנדבות נשמרה בהצלחה! ממתין לאישור מנהל.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- =================== PERSONAL SCREEN =================== -->
<div id="personal-screen" class="screen">
  <div class="personal-grid">
    <div class="section-title">👤 האזור האישי שלי</div>
    <div id="my-vol-list"></div>
  </div>
</div>

<!-- =================== ADMIN SCREEN =================== -->
