<!-- Confirm volunteer proposed hours -->
<div class="modal-overlay" id="confirm-proposed-modal">
  <div class="modal">
    <div class="modal-header" style="background:linear-gradient(135deg,#1e3a5f,#2563eb)">
      <h3>אישור שעות חדשות</h3>
      <button class="modal-close" onclick="closeModal('confirm-proposed-modal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="margin-bottom:4px;font-size:13px;color:var(--muted)">המנהל הציע שעות חדשות עבורך.</p>
      <p style="margin-bottom:14px;font-size:14px;font-weight:600;" id="cp-proposed-hours"></p>
      <p style="margin-bottom:14px;font-size:14px;">אנא הכנס את שמך המלא לאישור:</p>
      <div class="form-group">
        <input type="text" id="cp-name-confirm" placeholder="שם פרטי ושם משפחה" />
      </div>
      <div class="error-msg" id="cp-error">השם אינו תואם לשם הרשום. אנא הכנס את שמך המלא.</div>
      <button class="btn btn-propose" style="width:100%;color:white;margin-top:4px" onclick="confirmProposedAccept()">אשר שעות חדשות</button>
    </div>
  </div>
</div>

<script>
// ============= STATE =============
let currentUser = null;
let currentYear, currentMonth;
let selectedDate = null;
let pendingActionId = null;
let pendingConfirmId = null;

const DEFAULT_USERS = [
  { id: 'admin', username: 'כניסה1234', password: 'כניסה1234', fname: 'מנהל', lname: 'סניף', phone: '', email: '', isAdmin: true },
  { id: 'admin2', username: 'מנהל1234', password: 'מנהל1234', fname: 'מנהל', lname: 'ראשי', phone: '', email: '', isAdmin: true }
];

function loadUsers() {
  try {
    const saved = localStorage.getItem('vol_users');
    if (saved) {
      const parsed = JSON.parse(saved);
      const nonAdmins = parsed.filter(u => !u.isAdmin);
      return [...DEFAULT_USERS, ...nonAdmins];
    }
  } catch(e) {}
  return [...DEFAULT_USERS];
}
function saveUsers() {
  const nonAdmins = users.filter(u => !u.isAdmin);
  localStorage.setItem('vol_users', JSON.stringify([...DEFAULT_USERS, ...nonAdmins]));
}
function loadVolunteers() {
  try {
    const saved = localStorage.getItem('vol_requests');
    if (saved) return JSON.parse(saved);
  } catch(e) {}
  return [];
}
function saveVolunteers() {
  localStorage.setItem('vol_requests', JSON.stringify(volunteers));
}
function loadBanners() {
  try {
    const saved = localStorage.getItem('vol_banners');
    if (saved) return JSON.parse(saved);
  } catch(e) {}
  return [];
}
function saveBanners() {
  localStorage.setItem('vol_banners', JSON.stringify(banners));
}

let users = loadUsers();
let volunteers = loadVolunteers();
let banners = loadBanners();
let bannerActive = false;

// ============= LOGIN =============
function doLogin() {
  const u = document.getElementById('login-username').value.trim();
  const p = document.getElementById('login-password').value.trim();
  const found = users.find(x => x.username === u && x.password === p);
  if (!found) {
    document.getElementById('login-error').style.display = 'block';
    return;
  }
  document.getElementById('login-error').style.display = 'none';
  currentUser = found;
  afterLogin();
}

function afterLogin() {
  document.getElementById('login-screen').classList.remove('active');
  document.getElementById('user-greeting').textContent = `שלום, ${currentUser.fname} ${currentUser.lname}`;
  document.getElementById('user-greeting').style.display = 'inline';
  document.getElementById('logout-btn').style.display = 'inline';
  document.getElementById('calendar-btn').style.display = 'inline';
  document.getElementById('personal-btn').style.display = 'inline';

  if (currentUser.isAdmin) {
    document.getElementById('admin-btn').style.display = 'inline';
  }

  showCalendar();
}

function logout() {
  currentUser = null;
  selectedDate = null;
  ['login-screen','main-screen','admin-screen','personal-screen'].forEach(id => {
    document.getElementById(id).classList.remove('active');
  });
  document.getElementById('login-screen').classList.add('active');
  document.getElementById('user-greeting').style.display = 'none';
  document.getElementById('logout-btn').style.display = 'none';
  document.getElementById('calendar-btn').style.display = 'none';
  document.getElementById('personal-btn').style.display = 'none';
  document.getElementById('admin-btn').style.display = 'none';
  document.getElementById('login-username').value = '';
  document.getElementById('login-password').value = '';
}

// ============= SCREEN NAV =============
function showScreen(id) {
  ['main-screen','admin-screen','personal-screen'].forEach(s => {
    document.getElementById(s).classList.remove('active');
  });
  document.getElementById(id).classList.add('active');
}

function showCalendar() {
  showScreen('main-screen');
  renderCalendar();
}

function showAdmin() {
  showScreen('admin-screen');
  adminTab('requests');
}

function showPersonal() {
  showScreen('personal-screen');
  renderMyVolunteers();
}

// ============= CALENDAR =============
const MONTHS_HE = ['ינואר','פברואר','מרץ','אפריל','מאי','יוני','יולי','אוגוסט','ספטמבר','אוקטובר','נובמבר','דצמבר'];

function initCalendar() {
  const now = new Date();
  currentYear = now.getFullYear();
  currentMonth = now.getMonth();
}

function prevMonth() { currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; } renderCalendar(); }
function nextMonth() { currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; } renderCalendar(); }

function renderCalendar() {
  document.getElementById('cal-title').textContent = `${MONTHS_HE[currentMonth]} ${currentYear}`;
  const grid = document.getElementById('cal-grid');
  grid.innerHTML = '';

  const firstDay = new Date(currentYear, currentMonth, 1).getDay();
  const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
  const daysInPrev = new Date(currentYear, currentMonth, 0).getDate();
  const today = new Date();

  // prev month fill
  for (let i = 0; i < firstDay; i++) {
    const d = daysInPrev - firstDay + 1 + i;
    const cell = makeDay(d, currentMonth - 1, currentYear, true);
    grid.appendChild(cell);
  }

  // current month
  for (let d = 1; d <= daysInMonth; d++) {
    const isToday = d === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear();
    const cell = makeDay(d, currentMonth, currentYear, false, isToday);
    grid.appendChild(cell);
  }

  // next month fill
  const total = firstDay + daysInMonth;
  const remaining = total % 7 === 0 ? 0 : 7 - (total % 7);
  for (let d = 1; d <= remaining; d++) {
    const cell = makeDay(d, currentMonth + 1, currentYear, true);
    grid.appendChild(cell);
  }
}

function makeDay(d, month, year, otherMonth, isToday) {
  const cell = document.createElement('div');
  cell.className = 'cal-day' + (otherMonth ? ' other-month' : '') + (isToday ? ' today' : '');

  const numDiv = document.createElement('div');
  numDiv.className = 'day-num';
  numDiv.textContent = d;
  cell.appendChild(numDiv);

  const realMonth = (month + 12) % 12;
  const realYear = month < 0 ? year - 1 : (month > 11 ? year + 1 : year);
  const dateStr = `${realYear}-${String(realMonth + 1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;

  // Find vols for this day
  const dayVols = volunteers.filter(v => v.date === dateStr);
  dayVols.forEach(v => {
    const chip = document.createElement('div');
    chip.className = `vol-chip chip-${v.status}`;
    chip.textContent = `${v.fname} ${v.lname} ${v.status === 'proposed' ? v.proposedHours || v.hours : v.hours}`;
    chip.onclick = (e) => { e.stopPropagation(); openDayModal(dateStr); };
    cell.appendChild(chip);
  });

  if (!otherMonth) {
    cell.onclick = () => selectDay(dateStr, d);
  }
  return cell;
}

function selectDay(dateStr, d) {
  selectedDate = dateStr;
  document.getElementById('selected-date-label').textContent = `נבחר: ${formatDateHe(dateStr)}`;
  document.getElementById('vol-form-fields').style.display = 'block';
  document.getElementById('vol-success').style.display = 'none';

  // Pre-fill from current user
  document.getElementById('vf-fname').value = currentUser.fname;
  document.getElementById('vf-lname').value = currentUser.lname;
  document.getElementById('vf-phone').value = currentUser.phone || '';
  document.getElementById('vf-hours').value = '10:00-13:00';
  document.getElementById('vf-hours-note').value = '';
  document.getElementById('vf-notes').value = '';
}

function formatDateHe(dateStr) {
  const [y,m,d] = dateStr.split('-');
  return `${d}/${m}/${y}`;
}

function submitVolunteer() {
  if (!selectedDate) return;
  const hours = document.getElementById('vf-hours').value.trim() || '10:00-13:00';
  const hoursNote = document.getElementById('vf-hours-note').value.trim();
  const notes = document.getElementById('vf-notes').value.trim();

  const vol = {
    id: Date.now().toString(),
    userId: currentUser.id,
    fname: currentUser.fname,
    lname: currentUser.lname,
    phone: currentUser.phone || '',
    date: selectedDate,
    hours: hours,
    hoursNote: hoursNote,
    notes: notes,
    status: 'pending',
    rejectReason: '',
    proposedHours: '',
    proposedConfirmed: false,
    createdAt: new Date().toISOString()
  };

  volunteers.push(vol);
  saveVolunteers();
  document.getElementById('vol-success').style.display = 'block';
  document.getElementById('vol-form-fields').style.display = 'none';
  renderCalendar();
}

// ============= DAY MODAL =============
function openDayModal(dateStr) {
  const dayVols = volunteers.filter(v => v.date === dateStr);
  document.getElementById('day-modal-title').textContent = `התנדבויות – ${formatDateHe(dateStr)}`;
  const body = document.getElementById('day-modal-body');
  if (dayVols.length === 0) { body.innerHTML = '<p>אין התנדבויות ביום זה</p>'; }
  else {
    body.innerHTML = dayVols.map(v => `
      <div class="vol-request-item ${v.status}" style="margin-bottom:12px">
        <div class="req-name">${v.fname} ${v.lname}</div>
        <div class="req-detail">📅 ${formatDateHe(v.date)} | ⏰ ${v.hours}</div>
        ${v.hoursNote ? `<div class="req-detail">📝 ${v.hoursNote}</div>` : ''}
        ${v.notes ? `<div class="req-detail">💬 ${v.notes}</div>` : ''}
        <div class="req-detail">סטטוס: <span class="status-badge badge-${v.status}">${statusLabel(v.status)}</span></div>
        ${v.rejectReason ? `<div class="req-detail" style="color:var(--rejected)">❌ ${v.rejectReason}</div>` : ''}
        ${v.proposedHours ? `<div class="req-detail" style="color:var(--proposed)">🔵 שעות מוצעות: ${v.proposedHours}</div>` : ''}
        ${v.status === 'proposed' && v.proposedHours && !v.proposedConfirmed && currentUser.id === v.userId ? `
          <div style="margin-top:10px">
            <button class="btn btn-propose btn-sm" style="color:white" onclick="closeModal('day-modal');openConfirmProposed('${v.id}')">אשר שעות חדשות</button>
          </div>
        ` : ''}
      </div>
    `).join('');
  }
  openModal('day-modal');
}

// ============= PERSONAL AREA =============
function renderMyVolunteers() {
  const myVols = volunteers.filter(v => v.userId === currentUser.id);
  const list = document.getElementById('my-vol-list');

  if (myVols.length === 0) {
    list.innerHTML = '<div class="vol-form-card"><p style="color:var(--muted);text-align:center">אין לך עדיין בקשות התנדבות. בחר יום בלוח השנה!</p></div>';
    return;
  }

  list.innerHTML = myVols.map(v => `
    <div class="my-vol-card">
      <div class="my-vol-header ${v.status}">
        <div>
          <div style="font-weight:700;font-size:15px">${formatDateHe(v.date)}</div>
          <div style="font-size:13px;margin-top:2px">⏰ ${v.status === 'proposed' && v.proposedHours ? v.proposedHours : v.hours}</div>
          ${v.hoursNote ? `<div style="font-size:12px;color:var(--muted)">${v.hoursNote}</div>` : ''}
        </div>
        <span class="status-badge badge-${v.status}">${statusLabel(v.status)}</span>
      </div>
      ${v.rejectReason ? `<div style="padding:12px 20px;background:#fef2f2;color:var(--rejected);font-size:13px">❌ סיבת דחייה: ${v.rejectReason}</div>` : ''}
      ${v.status === 'proposed' && v.proposedHours && !v.proposedConfirmed && currentUser.id === v.userId ? `
        <div class="confirm-proposed-row">
          <span style="font-size:13px;color:var(--proposed)">🔵 המנהל הציע שעות חדשות: <strong>${v.proposedHours}</strong></span>
          <button class="btn btn-propose btn-sm" style="color:white" onclick="openConfirmProposed('${v.id}')">אשר / דחה</button>
        </div>
      ` : ''}
    </div>
  `).join('');
}

function openConfirmProposed(volId) {
  pendingConfirmId = volId;
  const vol = volunteers.find(v => v.id === volId);
  document.getElementById('cp-proposed-hours').textContent = `שעות מוצעות: ${vol.proposedHours}`;
  document.getElementById('cp-name-confirm').value = '';
  document.getElementById('cp-error').style.display = 'none';
  openModal('confirm-proposed-modal');
}

function confirmProposedAccept() {
  const vol = volunteers.find(v => v.id === pendingConfirmId);
  const entered = document.getElementById('cp-name-confirm').value.trim();
  const expected = `${vol.fname} ${vol.lname}`;
  if (entered !== expected) {
    document.getElementById('cp-error').style.display = 'block';
    return;
  }
  vol.hours = vol.proposedHours;
  vol.status = 'approved';
  vol.proposedConfirmed = true;
  saveVolunteers();
  closeModal('confirm-proposed-modal');
  renderCalendar();
  renderMyVolunteers();
}

// ============= ADMIN =============
function adminTab(tab) {
  ['requests','users','banners'].forEach(t => {
    document.getElementById(`admin-${t}`).style.display = 'none';
  });
  document.querySelectorAll('.nav-tab').forEach((el, i) => {
    el.classList.remove('active');
  });
  document.getElementById(`admin-${tab}`).style.display = 'block';
  const tabs = document.querySelectorAll('.nav-tab');
  const idx = ['requests','users','banners'].indexOf(tab);
  tabs[idx].classList.add('active');

  if (tab === 'requests') renderAdminRequests();
  if (tab === 'users') renderUsersList();
  if (tab === 'banners') renderBannerList();
}

function renderAdminRequests() {
  const list = document.getElementById('admin-vol-list');
  if (volunteers.length === 0) {
    list.innerHTML = '<div class="admin-card"><div class="admin-card-body"><p style="color:var(--muted)">אין בקשות התנדבות</p></div></div>';
    return;
  }

  // Group by date
  const byDate = {};
  volunteers.forEach(v => {
    if (!byDate[v.date]) byDate[v.date] = [];
    byDate[v.date].push(v);
  });

  const sorted = Object.keys(byDate).sort();
  list.innerHTML = sorted.map(date => `
    <div class="admin-card" style="margin-bottom:20px">
      <div class="admin-card-header">📅 ${formatDateHe(date)} – ${byDate[date].length} בקשה/ות</div>
      <div class="admin-card-body">
        ${byDate[date].map(v => `
          <div class="vol-request-item ${v.status}">
            <div class="req-name">${v.fname} ${v.lname}</div>
            <div class="req-detail">📞 ${v.phone || '—'} | ⏰ ${v.hours}</div>
            ${v.hoursNote ? `<div class="req-detail">📝 ${v.hoursNote}</div>` : ''}
            ${v.notes ? `<div class="req-detail">💬 ${v.notes}</div>` : ''}
            <div class="req-detail">סטטוס: <span class="status-badge badge-${v.status}">${statusLabel(v.status)}</span></div>
            ${v.rejectReason ? `<div class="req-detail" style="color:var(--rejected)">❌ ${v.rejectReason}</div>` : ''}
            ${v.proposedHours ? `<div class="req-detail" style="color:var(--proposed)">🔵 שעות מוצעות: ${v.proposedHours}</div>` : ''}
            <div class="req-actions">
              ${v.status !== 'approved' ? `<button class="btn btn-approve btn-sm" onclick="approveVol('${v.id}')">✅ אשר</button>` : ''}
              ${v.status !== 'rejected' ? `<button class="btn btn-reject btn-sm" onclick="openReject('${v.id}')">❌ דחה</button>` : ''}
              ${v.status !== 'proposed' ? `<button class="btn btn-propose btn-sm" style="color:white" onclick="openPropose('${v.id}')">🔵 הצע שעות</button>` : ''}
            </div>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}

function approveVol(id) {
  const v = volunteers.find(x => x.id === id);
  if (v) { v.status = 'approved'; v.rejectReason = ''; }
  saveVolunteers();
  renderAdminRequests();
  renderCalendar();
}

function openReject(id) {
  pendingActionId = id;
  document.getElementById('reject-reason').value = '';
  openModal('reject-modal');
}

function confirmReject() {
  const reason = document.getElementById('reject-reason').value.trim();
  const v = volunteers.find(x => x.id === pendingActionId);
  if (v) { v.status = 'rejected'; v.rejectReason = reason; }
  saveVolunteers();
  closeModal('reject-modal');
  renderAdminRequests();
  renderCalendar();
}

function openPropose(id) {
  pendingActionId = id;
  document.getElementById('propose-hours').value = '';
  openModal('propose-modal');
}

function confirmPropose() {
  const hours = document.getElementById('propose-hours').value.trim();
  const v = volunteers.find(x => x.id === pendingActionId);
  if (v && hours) { v.status = 'proposed'; v.proposedHours = hours; }
  saveVolunteers();
  closeModal('propose-modal');
  renderAdminRequests();
  renderCalendar();
}

// ============= USERS =============
function renderUsersList() {
  const list = document.getElementById('users-list');
  const nonAdmin = users.filter(u => !u.isAdmin);
  if (nonAdmin.length === 0) {
    list.innerHTML = '<div class="vol-form-card"><p style="color:var(--muted);text-align:center">אין משתמשים עובדים עדיין</p></div>';
    return;
  }
  list.innerHTML = nonAdmin.map(u => `
    <div class="user-item">
      <div class="user-item-info">
        <div class="name">${u.fname} ${u.lname}</div>
        <div class="sub">👤 ${u.username} | 📞 ${u.phone || '—'} | ✉️ ${u.email || '—'}</div>
      </div>
      <div class="user-item-actions">
        <button class="btn btn-outline btn-sm" onclick="openEditUser('${u.id}')">ערוך</button>
        <button class="btn btn-danger btn-sm" onclick="deleteUser('${u.id}')">מחק</button>
      </div>
    </div>
  `).join('');
}

function openAddUserModal() {
  document.getElementById('user-modal-title').textContent = 'הוספת משתמש';
  document.getElementById('um-editing-id').value = '';
  ['fname','lname','phone','email','username','password'].forEach(f => {
    document.getElementById('um-' + f).value = '';
  });
  document.getElementById('um-error').style.display = 'none';
  openModal('user-modal');
}

function openEditUser(id) {
  const u = users.find(x => x.id === id);
  document.getElementById('user-modal-title').textContent = 'עריכת משתמש';
  document.getElementById('um-editing-id').value = id;
  document.getElementById('um-fname').value = u.fname;
  document.getElementById('um-lname').value = u.lname;
  document.getElementById('um-phone').value = u.phone || '';
  document.getElementById('um-email').value = u.email || '';
  document.getElementById('um-username').value = u.username;
  document.getElementById('um-password').value = u.password;
  document.getElementById('um-error').style.display = 'none';
  openModal('user-modal');
}

function saveUser() {
  const fname = document.getElementById('um-fname').value.trim();
  const lname = document.getElementById('um-lname').value.trim();
  const username = document.getElementById('um-username').value.trim();
  const password = document.getElementById('um-password').value.trim();

  if (!fname || !lname || !username || !password) {
    document.getElementById('um-error').style.display = 'block';
    return;
  }

  const editId = document.getElementById('um-editing-id').value;
  const phone = document.getElementById('um-phone').value.trim();
  const email = document.getElementById('um-email').value.trim();

  if (editId) {
    const u = users.find(x => x.id === editId);
    Object.assign(u, { fname, lname, phone, email, username, password });
  } else {
    // Use username as id so it stays stable across sessions
    const newId = 'user_' + username.replace(/\s+/g, '_');
    // If editing existing by username, update; else push new
    const existing = users.find(u => u.id === newId);
    if (existing) { Object.assign(existing, { fname, lname, phone, email, username, password }); }
    else { users.push({ id: newId, fname, lname, phone, email, username, password, isAdmin: false }); }
  }
  saveUsers();
  closeModal('user-modal');
  renderUsersList();
}

function deleteUser(id) {
  if (!confirm('האם אתה בטוח שברצונך למחוק משתמש זה?')) return;
  users = users.filter(u => u.id !== id);
  saveUsers();
  renderUsersList();
}

// ============= BANNERS =============
function addBanner() {
  const text = document.getElementById('banner-text-input').value.trim();
  if (!text) return;
  banners.push({ id: Date.now().toString(), text, active: true });
  document.getElementById('banner-text-input').value = '';
  updateBannerDisplay();
  renderBannerList();
}

function deleteBanner(id) {
  banners = banners.filter(b => b.id !== id);
  updateBannerDisplay();
  renderBannerList();
}

function updateBannerDisplay() {
  const active = banners.filter(b => b.active);
  const area = document.getElementById('banner-area');
  if (active.length === 0) { area.style.display = 'none'; return; }
  area.style.display = 'block';
  area.innerHTML = '📢 ' + active.map(b => b.text).join(' | ');
}

function renderBannerList() {
  const list = document.getElementById('banner-list');
  if (banners.length === 0) { list.innerHTML = '<p style="color:var(--muted)">אין באנרים</p>'; return; }
  list.innerHTML = banners.map(b => `
    <div class="banner-list-item">
      <span>📢 ${b.text}</span>
      <button class="btn btn-danger btn-sm" onclick="deleteBanner('${b.id}')">מחק</button>
    </div>
  `).join('');
}

// ============= MODALS =============
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// Close on outside click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

// Enter key login
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('login-screen').classList.contains('active')) doLogin();
});

// ============= HELPERS =============
function statusLabel(s) {
  return { pending: 'ממתין לאישור', approved: 'אושר', rejected: 'נדחה', proposed: 'שעות חדשות הוצעו' }[s] || s;
}

// ============= PASSWORD TOGGLE =============
function togglePw(inputId, btn) {
  const input = document.getElementById(inputId);
  if (input.type === 'password') {
    input.type = 'text';
    btn.textContent = '🙈';
  } else {
    input.type = 'password';
    btn.textContent = '👁️';
  }
}

// ============= INIT =============
initCalendar();
updateBannerDisplay();
</script>
</body>
</html>
